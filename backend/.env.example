# --- C3 PoC backend config ---
DATABASE_URL=sqlite:///./c3.db          # Postgres in prod: postgresql+psycopg://user:pass@host/db
SESSION_SECRET=change-me-in-prod
FRONTEND_ORIGIN=http://localhost:3000

# Google login — reuse the 8thloop GCP project (add a C3 redirect URI). No new project.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
ALLOWED_LOGIN_DOMAIN=8thloop.com

# GCMS (creds already exist in coupon-svp/.env)
GCMS_GRAPHQL_ENDPOINT=
GCMS_USERNAME=
GCMS_PASSWORD=

# Claude copilot/agents (key already exists in coupon-engine/.env)
ANTHROPIC_API_KEY=
